# Supabase project settings are entered in the Reef Command app UI.
# Edge Function secrets are set with:
# supabase secrets set OPENAI_API_KEY=your_openai_key
# supabase secrets set OPENAI_MODEL=gpt-5.4
# Optional, comma-separated list. When set, only these signed-in emails can run GPT insights:
# supabase secrets set REEF_ALLOWED_EMAILS=you@example.com
# Edge Function auth helper, set from the project service-role key:
# supabase secrets set SERVICE_ROLE_KEY=your_service_role_key
